{
  "name": "@bannersin48/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed API client for Banners In 48. Hand-written against shared schemas now; will be regenerated from backend openapi.json when M1 ships.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mocks/browser": "./src/mocks/browser.ts",
    "./mocks/server": "./src/mocks/server.ts",
    "./mocks/handlers": "./src/mocks/handlers.ts",
    "./mocks/fixtures": "./src/mocks/fixtures.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bannersin48/shared": "*"
  },
  "devDependencies": {
    "typescript": "~5.4.5",
    "msw": "^2.4.0"
  }
}
