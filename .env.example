# Copy to .env and fill in real values

# Database
DATABASE_URL="postgresql://banners:banners@localhost:5432/bannersin48?schema=public"
REDIS_URL="redis://localhost:6379"

# Backend
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Storage: "local" (dev) or "s3"
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Payment providers (stubs run without keys)
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# FedEx (stub runs without keys)
# FEDEX_API_KEY=
# FEDEX_SECRET_KEY=
# FEDEX_ACCOUNT_NUMBER=

# Cancellation window (override in tests; default 10 minutes)
CANCELLATION_WINDOW_MS=600000
